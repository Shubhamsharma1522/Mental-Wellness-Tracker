{
    "env": {
        "browser": true,
        "es2021": true,
        "node": true,
        "jest": true
    },
    "extends": "eslint:recommended",
    "parserOptions": {
        "ecmaVersion": "latest",
        "sourceType": "script"
    },
    "rules": {
        "no-unused-vars": "warn",
        "no-console": "off",
        "strict": ["error", "safe"],
        "eqeqeq": ["error", "always"],
        "no-eval": "error",
        "no-implied-eval": "error",
        "no-new-func": "error",
        "no-script-url": "error",
        "prefer-const": "warn",
        "no-var": "warn"
    },
    "overrides": [
        {
            "files": ["api/**/*.js"],
            "parserOptions": {
                "sourceType": "module"
            },
            "rules": {
                "strict": "off"
            }
        },
        {
            "files": ["test/**/*.js", "jest.config.js"],
            "parserOptions": {
                "sourceType": "script"
            },
            "rules": {
                "strict": "off"
            }
        }
    ]
}
